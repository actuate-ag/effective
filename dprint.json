{
	"typescript": {
		"indentWidth": 2,
		"useTabs": true,
		"semiColons": "always",
		"quoteStyle": "preferSingle"
	},
	"json": {
		"indentWidth": 2,
		"useTabs": true
	},
	"includes": ["**/*.{ts,tsx,json}"],
	"excludes": [
		"node_modules",
		".references",
		"**/*-lock.json",
		"bun.lock",
		"bun.lockb"
	],
	"plugins": [
		"https://plugins.dprint.dev/typescript-0.93.0.wasm",
		"https://plugins.dprint.dev/json-0.19.4.wasm"
	]
}
