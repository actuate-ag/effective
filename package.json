{
	"name": "effective",
	"version": "0.0.1",
	"private": true,
	"description": "Claude Code plugin: skills, hooks, and guidance for writing Effect v4 TypeScript",
	"scripts": {
		"check": "tsc --noEmit",
		"test": "vitest run",
		"lint": "oxlint --fix hooks/ scripts/ src/ test/",
		"format": "oxfmt --write 'hooks/**/*.ts' 'scripts/**/*.ts' 'src/**/*.ts' 'test/**/*.ts'",
		"format:check": "oxfmt --check 'hooks/**/*.ts' 'scripts/**/*.ts' 'src/**/*.ts' 'test/**/*.ts'"
	},
	"devDependencies": {
		"@types/bun": "^1.1.0",
		"@types/node": "^22.0.0",
		"@types/picomatch": "^4.0.3",
		"gray-matter": "^4.0.3",
		"oxfmt": "0.43.0",
		"oxlint": "1.58.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"bun": ">=1.1.0"
	},
	"dependencies": {
		"@ast-grep/napi": "^0.42.1",
		"@effect/platform-bun": "4.0.0-beta.59",
		"@effect/vitest": "4.0.0-beta.59",
		"effect": "4.0.0-beta.59",
		"picomatch": "^4.0.4",
		"yaml": "^2.8.4"
	}
}
