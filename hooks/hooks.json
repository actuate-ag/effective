{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/ensure-reference-clone.ts\""
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit|NotebookEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/pattern-feedback.ts\""
					}
				]
			}
		]
	}
}
